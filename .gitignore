.DS_Store
*.log
.env

# Atelier runtime state — written via ctx.dataDir, never shipped.
data/

# Module deps (only present if the module declares its own package.json).
node_modules/

# Claude Code: ignore everything in .claude/ by default (runtime state),
# whitelist only the definitional dirs we actively use. Mirrors Atelier's
# deploy filter (see atelier/atelier.js DEPLOY_FILTERS).
.claude/*
!.claude/agents/
!.claude/skills/
!.claude/commands/
!.claude/hooks/
!.claude/CLAUDE.md
!.claude/settings.json
